# Register your app at https://developers.eveonline.com/
# Callback URL must match exactly what you register there
EVE_CLIENT_ID=your_eve_client_id_here
EVE_CLIENT_SECRET=your_eve_client_secret_here
SECRET_KEY=change_this_to_a_long_random_string_for_session_signing

# Must match the callback URL registered in the EVE developer portal
CALLBACK_URL=http://localhost:8000/auth/callback

# URL of the frontend (for CORS and post-auth redirects)
FRONTEND_URL=http://localhost:5173
